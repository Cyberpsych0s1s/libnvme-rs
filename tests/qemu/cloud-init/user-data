#cloud-config
# Minimal cloud-init for libnvme-rs QEMU test fixture.
#
# This is Phase 1: just create a login-able user so you can manually
# verify the guest sees /dev/nvme0. Phase 2 will add cargo / libnvme-dev
# installation and a 9p host share for running tests automatically.

hostname: nvme-test

users:
  - name: tester
    groups: [sudo, disk]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    shell: /bin/bash

# Canonical syntax for setting passwords from cloud-init (the older
# `plain_text_passwd` field on the user above is silently ignored on
# Ubuntu 24.04's cloud-init).
chpasswd:
  expire: false
  users:
    - { name: tester, password: nvmenvme, type: text }

ssh_pwauth: true

package_update: false
package_upgrade: false

# Make sure the console prompt shows up quickly so it's obvious the
# guest is ready.
final_message: "*** libnvme-rs QEMU guest ready. Login: tester / nvmenvme ***"
