#cloud-config
# Cloud-init for the libnvme-rs QEMU test fixture (Phase 2).
#
# Provisions an Ubuntu 24.04 guest with everything needed to build and
# test libnvme-rs against the virtual NVMe device, mounted via 9p from
# the host's working copy of the repo.

hostname: nvme-test

users:
  - name: tester
    groups: [sudo, disk]
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    shell: /bin/bash

# Canonical syntax for setting passwords from cloud-init (the older
# `plain_text_passwd` field on the user above is silently ignored on
# Ubuntu 24.04's cloud-init).
chpasswd:
  expire: false
  users:
    - { name: tester, password: nvmenvme, type: text }

ssh_pwauth: true

# First boot installs everything we need for `cargo build` + the bindgen
# step + Get Log Page admin commands.
package_update: true
package_upgrade: false
packages:
  - build-essential
  - pkg-config
  - libnvme-dev
  - clang
  - libclang-dev
  - nvme-cli
  - rustup
  - curl
  - ca-certificates

# Mount the host's working copy of the repo at /mnt/host via 9p, and
# initialize rustup for the tester user so `cargo` is on the path.
#
# We also write an /etc/fstab entry with `nofail` so the mount comes back
# automatically on subsequent boots. The runcmd `mount` is for the first
# boot only — cloud-init runs after rc.local/systemd targets, so fstab
# alone wouldn't help.
runcmd:
  - mkdir -p /mnt/host
  - |
    printf 'hostshare /mnt/host 9p trans=virtio,version=9p2000.L,rw,access=any,nofail,_netdev 0 0\n' \
      >> /etc/fstab
  - |
    mount -t 9p -o trans=virtio,version=9p2000.L,rw,access=any \
      hostshare /mnt/host \
      || echo "9p mount failed (run.sh likely missing -virtfs flag)"
  - su - tester -c 'rustup default stable'
  - |
    cat >> /home/tester/.bashrc <<'EOF'
    # Speed up cargo builds: keep target/ on guest-local fs, not the
    # 9p share (writes through 9p are slow).
    export CARGO_TARGET_DIR=/tmp/target
    cd /mnt/host 2>/dev/null || true
    EOF
  - chown tester:tester /home/tester/.bashrc

final_message: |
  *** libnvme-rs QEMU guest ready ***
  Login: tester / nvmenvme
  Host repo is mounted at /mnt/host.
  Quick test inside the guest:
    cargo build --workspace --all-targets
    sudo -E env "PATH=$PATH" cargo test --workspace
